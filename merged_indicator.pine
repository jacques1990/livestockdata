//@version=6
indicator("MTF Dashboard + S/R Zones + EMA Angle System", overlay=true, max_lines_count=500, max_boxes_count=500)

// ============================================================
//  SECTION 1 — INPUTS
// ============================================================

// --- MTF / Strike ---
step = input.int(50, "Strike Step", group="MTF Dashboard")

// --- S/R Zones ---
pivotStrength = input.int(2,    "Pivot Strength",  group="S/R Zones")
zonePercent   = input.float(0.30, "Zone Width %",  group="S/R Zones")
extendBars    = input.int(80,   "Zone Extend Bars", group="S/R Zones")

// --- EMA Angle System ---
emaFastLen    = input.int(9,    "EMA Fast Length",         group="EMA Angle")
emaSlowLen    = input.int(20,   "EMA Slow Length",         group="EMA Angle")
slopeLookback = input.int(6,    "Slope Lookback",          group="EMA Angle")
atrLen        = input.int(14,   "ATR Length",              group="EMA Angle")
minSlopeATR   = input.float(0.05, "Min Slope (ATR mult)",  group="EMA Angle", step=0.01)
cooldownBars  = input.int(8,    "Cooldown After EMA Cross", group="EMA Angle", minval=0)


// ============================================================
//  SECTION 2 — MTF SIGNAL FUNCTION
// ============================================================
getSignal(tf) =>
    price   = request.security(syminfo.tickerid, tf, close)
    ema9    = request.security(syminfo.tickerid, tf, ta.ema(close, 9))
    ema20   = request.security(syminfo.tickerid, tf, ta.ema(close, 20))
    ema200  = request.security(syminfo.tickerid, tf, ta.ema(close, 200))
    rsiVal  = request.security(syminfo.tickerid, tf, ta.rsi(close, 14))

    fastEMA    = request.security(syminfo.tickerid, tf, ta.ema(close, 12))
    slowEMA    = request.security(syminfo.tickerid, tf, ta.ema(close, 26))
    macdLine   = fastEMA - slowEMA
    signalLine = request.security(syminfo.tickerid, tf, ta.ema(macdLine, 9))

    emaBull  = price > ema9  and ema9 > ema20
    emaBear  = price < ema9  and ema9 < ema20
    trendBull = price > ema200
    trendBear = price < ema200
    rsiBull  = rsiVal > 55
    rsiBear  = rsiVal < 45
    macdBull = macdLine > signalLine
    macdBear = macdLine < signalLine

    bullScore = (emaBull  ? 1 : 0) + (trendBull ? 1 : 0) + (rsiBull ? 1 : 0) + (macdBull ? 1 : 0)
    bearScore = (emaBear  ? 1 : 0) + (trendBear ? 1 : 0) + (rsiBear ? 1 : 0) + (macdBear ? 1 : 0)

    sig      = bullScore >= 3 ? 1 : bearScore >= 3 ? -1 : 0
    strength = math.max(bullScore, bearScore)
    [sig, strength]

[sig1m,  str1m]  = getSignal("1")
[sig3m,  str3m]  = getSignal("3")
[sig15m, str15m] = getSignal("15")
[sig30m, str30m] = getSignal("30")

alignedBull  = sig1m == 1  and sig3m == 1  and sig15m == 1  and sig30m == 1
alignedBear  = sig1m == -1 and sig3m == -1 and sig15m == -1 and sig30m == -1
avgStrength  = (str1m + str3m + str15m + str30m) / 4.0

// Strike type
strikeType  = "NO TRADE"
strikeColor = color.gray

if alignedBull or alignedBear
    if avgStrength >= 3.5
        strikeType  := "DEEP ITM"
        strikeColor := color.purple
    else if avgStrength >= 3
        strikeType  := "ITM"
        strikeColor := color.blue
    else
        strikeType  := "ATM"
        strikeColor := color.green
else
    if str1m >= 3
        strikeType  := "ATM SCALP"
        strikeColor := color.yellow

// Strike levels
atm         = math.round(close / step) * step
maxDistance = step * 1.2
callStrike  = atm
putStrike   = atm

if strikeType == "ITM"
    callStrike := math.abs(close - (atm - step))         <= maxDistance ? atm - step         : atm
    putStrike  := math.abs(close - (atm + step))         <= maxDistance ? atm + step         : atm

if strikeType == "DEEP ITM"
    callStrike := math.abs(close - (atm - 2 * step))     <= maxDistance ? atm - 2 * step     : atm
    putStrike  := math.abs(close - (atm + 2 * step))     <= maxDistance ? atm + 2 * step     : atm

direction   = alignedBull ? "CALL" : alignedBear ? "PUT" : "NONE"
finalStrike = "-"
if direction == "CALL"
    finalStrike := str.tostring(callStrike)
else if direction == "PUT"
    finalStrike := str.tostring(putStrike)


// ============================================================
//  SECTION 3 — CBC TREND
// ============================================================
var bool cbc = false
if bar_index > 0
    cbc := cbc[1]
if bar_index > 0
    if cbc and close < low[1]
        cbc := false
    if not cbc and close > high[1]
        cbc := true

cbcBull = cbc
cbcBear = not cbc

// CBC background flash on flip
bgcolor(cbc and not cbc[1]  ? color.new(color.yellow, 75) :
        not cbc and cbc[1]  ? color.new(color.blue,   75) : na)

// CBC flip arrows
plotshape(not cbc and cbc[1], style=shape.triangledown, location=location.abovebar, color=color.red,   size=size.small)
plotshape(cbc and not cbc[1], style=shape.triangleup,   location=location.belowbar, color=color.green, size=size.small)


// ============================================================
//  SECTION 4 — EMA PLOTS (shared fast/slow for angle + CBC)
// ============================================================
emaFast = ta.ema(close, emaFastLen)   // default 9
emaSlow = ta.ema(close, emaSlowLen)   // default 20

plot(emaFast, "EMA Fast", color=color.white,  linewidth=2)
plot(emaSlow, "EMA Slow", color=color.orange, linewidth=2)


// ============================================================
//  SECTION 5 — S/R ZONES (Pivot-based)
// ============================================================
ph = ta.pivothigh(high, pivotStrength, pivotStrength)
pl = ta.pivotlow(low,  pivotStrength, pivotStrength)

var float[] resAll = array.new_float()
var float[] supAll = array.new_float()
var line[]  rLines = array.new_line()
var line[]  sLines = array.new_line()
var box[]   rBoxes = array.new_box()
var box[]   sBoxes = array.new_box()

if not na(ph)
    array.push(resAll, ph)
    zone = ph * zonePercent / 100
    array.push(rBoxes, box.new(bar_index, ph + zone, bar_index + extendBars, ph - zone,
         bgcolor=color.new(color.red, 85), border_color=color.red))
    array.push(rLines, line.new(bar_index, ph, bar_index + extendBars, ph,
         color=color.red, width=2))

if not na(pl)
    array.push(supAll, pl)
    zone = pl * zonePercent / 100
    array.push(sBoxes, box.new(bar_index, pl + zone, bar_index + extendBars, pl - zone,
         bgcolor=color.new(color.green, 85), border_color=color.green))
    array.push(sLines, line.new(bar_index, pl, bar_index + extendBars, pl,
         color=color.green, width=2))

// Nearest levels
float rLevel = na
float sLevel = na

if array.size(resAll) > 0
    for i = 0 to array.size(resAll) - 1
        val = array.get(resAll, i)
        if val > close
            rLevel := na(rLevel) ? val : math.min(rLevel, val)

if array.size(supAll) > 0
    for i = 0 to array.size(supAll) - 1
        val = array.get(supAll, i)
        if val < close
            sLevel := na(sLevel) ? val : math.max(sLevel, val)


// ============================================================
//  SECTION 6 — EMA ANGLE SYSTEM (LB / LS / DT / EX)
// ============================================================
atr       = ta.atr(atrLen)
slopeFast = (emaFast - emaFast[slopeLookback]) / atr
slopeSlow = (emaSlow - emaSlow[slopeLookback]) / atr

angledUp   = slopeFast >  minSlopeATR and slopeSlow >  minSlopeATR
angledDown = slopeFast < -minSlopeATR and slopeSlow < -minSlopeATR
flatEMAs   = not angledUp and not angledDown

emaCross = ta.cross(emaFast, emaSlow)

var int lastCrossBar = na
if emaCross
    lastCrossBar := bar_index

inCooldown = cooldownBars > 0 and not na(lastCrossBar) and (bar_index - lastCrossBar) <= cooldownBars
dontTrade  = flatEMAs or emaCross or inCooldown

isGreen = close > open
isRed   = close < open
trendUp   = emaFast > emaSlow
trendDown = emaFast < emaSlow

longSignal  = (not dontTrade) and angledUp   and trendUp   and isGreen
shortSignal = (not dontTrade) and angledDown and trendDown and isRed
exLong      = (not dontTrade) and angledUp   and trendUp   and isRed
exShort     = (not dontTrade) and angledDown and trendDown and isGreen
exSignal    = exLong or exShort

var label dtLbl = na
var label lbLbl = na
var label lsLbl = na
var label exLbl = na

if barstate.isrealtime
    // DT
    if dontTrade
        if na(dtLbl)
            dtLbl := label.new(bar_index, high, "DT", style=label.style_label_down, color=color.gray,   textcolor=color.white, size=size.tiny)
        else
            label.set_x(dtLbl, bar_index), label.set_y(dtLbl, high)
    else
        if not na(dtLbl)
            label.delete(dtLbl)
            dtLbl := na

    // LB
    if longSignal
        if na(lbLbl)
            lbLbl := label.new(bar_index, low, "LB", style=label.style_label_up, color=color.green, textcolor=color.white, size=size.small)
        else
            label.set_x(lbLbl, bar_index), label.set_y(lbLbl, low)
    else
        if not na(lbLbl)
            label.delete(lbLbl)
            lbLbl := na

    // LS
    if shortSignal
        if na(lsLbl)
            lsLbl := label.new(bar_index, high, "LS", style=label.style_label_down, color=color.red, textcolor=color.white, size=size.small)
        else
            label.set_x(lsLbl, bar_index), label.set_y(lsLbl, high)
    else
        if not na(lsLbl)
            label.delete(lsLbl)
            lsLbl := na

    // EX
    exY   = exLong ? high : low
    exSty = exLong ? label.style_label_down : label.style_label_up
    if exSignal
        if na(exLbl)
            exLbl := label.new(bar_index, exY, "EX", style=exSty, color=color.orange, textcolor=color.white, size=size.tiny)
        else
            label.set_x(exLbl, bar_index), label.set_y(exLbl, exY), label.set_style(exLbl, exSty)
    else
        if not na(exLbl)
            label.delete(exLbl)
            exLbl := na


// ============================================================
//  SECTION 7 — CBC + S/R ZONE ENTRY SIGNALS
// ============================================================
rng    = high - low
body   = math.abs(close - open)
upperW = high - math.max(open, close)
lowerW = math.min(open, close) - low

upperPct = rng > 0 ? upperW / rng : 0.0
lowerPct = rng > 0 ? lowerW / rng : 0.0
rangeOK  = rng >= syminfo.mintick * 3

touchSup = not na(sLevel) and low  <= sLevel
touchRes = not na(rLevel) and high >= rLevel

bullBody  = close > open and body > rng * 0.25
bearBody  = close < open and body > rng * 0.25
emaSlope  = emaFast - emaFast[1]
bullSlope = emaSlope > 0
bearSlope = emaSlope < 0
emaBullLocal = emaFast > emaSlow and close > emaFast
emaBearLocal = emaFast < emaSlow and close < emaFast

buySignal =
     rangeOK   and touchSup and
     lowerPct >= 0.45 and upperPct <= 0.25 and
     emaBullLocal and bullBody and bullSlope and cbcBull

sellSignal =
     rangeOK   and touchRes and
     upperPct >= 0.45 and lowerPct <= 0.25 and
     emaBearLocal and bearBody and bearSlope and cbcBear

// Entry labels (B / S)
var label entryLbl = na
if barstate.islast
    label.delete(entryLbl)
    if buySignal
        entryLbl := label.new(bar_index, low,  "B", style=label.style_label_up,   color=color.green, textcolor=color.white)
    else if sellSignal
        entryLbl := label.new(bar_index, high, "S", style=label.style_label_down, color=color.red,   textcolor=color.white)

alertcondition(buySignal,  "BUY",  "CBC + Support Bounce")
alertcondition(sellSignal, "SELL", "CBC + Resistance Rejection")


// ============================================================
//  SECTION 8 — DASHBOARD (top-right)
// ============================================================
getColor(sig) =>
    sig == 1 ? color.green : sig == -1 ? color.red : color.gray

getText(sig) =>
    sig == 1 ? "BUY" : sig == -1 ? "SELL" : "WAIT"

// Angle label helper
angleLabel() =>
    longSignal ? "LB" : shortSignal ? "LS" : exSignal ? "EX" : dontTrade ? "DT" : "--"

angleColor() =>
    longSignal ? color.green : shortSignal ? color.red : exSignal ? color.orange : color.gray

var table dash = table.new(position.top_right, 4, 9, border_width=1)

if barstate.islast
    // Header
    table.cell(dash, 0, 0, "TF",       bgcolor=color.black, text_color=color.white)
    table.cell(dash, 1, 0, "Signal",   bgcolor=color.black, text_color=color.white)
    table.cell(dash, 2, 0, "Strength", bgcolor=color.black, text_color=color.white)

    // MTF rows
    table.cell(dash, 0, 1, "1m")
    table.cell(dash, 1, 1, getText(sig1m),  bgcolor=getColor(sig1m),  text_color=color.white)
    table.cell(dash, 2, 1, str.tostring(str1m)  + "/4")

    table.cell(dash, 0, 2, "3m")
    table.cell(dash, 1, 2, getText(sig3m),  bgcolor=getColor(sig3m),  text_color=color.white)
    table.cell(dash, 2, 2, str.tostring(str3m)  + "/4")

    table.cell(dash, 0, 3, "15m")
    table.cell(dash, 1, 3, getText(sig15m), bgcolor=getColor(sig15m), text_color=color.white)
    table.cell(dash, 2, 3, str.tostring(str15m) + "/4")

    table.cell(dash, 0, 4, "30m")
    table.cell(dash, 1, 4, getText(sig30m), bgcolor=getColor(sig30m), text_color=color.white)
    table.cell(dash, 2, 4, str.tostring(str30m) + "/4")

    // Alignment
    table.cell(dash, 0, 5, "ALIGN")
    table.cell(dash, 1, 5,
         alignedBull ? "STRONG BUY"  :
         alignedBear ? "STRONG SELL" : "NO TRADE",
         bgcolor =
             alignedBull ? color.green :
             alignedBear ? color.red   : color.gray,
         text_color=color.white)

    // Strike
    table.cell(dash, 0, 6, "STRIKE")
    table.cell(dash, 1, 6, direction + " " + finalStrike, bgcolor=strikeColor, text_color=color.white)

    // EMA Angle signal
    table.cell(dash, 0, 7, "ANGLE")
    table.cell(dash, 1, 7, angleLabel(), bgcolor=angleColor(), text_color=color.white)

    // CBC state
    table.cell(dash, 0, 8, "CBC")
    table.cell(dash, 1, 8, cbc ? "BULL" : "BEAR",
         bgcolor = cbc ? color.green : color.red,
         text_color=color.white)
